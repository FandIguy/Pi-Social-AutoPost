# Copy to ~/.config/autopost.env and fill in your values, then:
#   chmod 600 ~/.config/autopost.env

# Your Zernio API key (sk_ + 64 hex chars). Keep this secret.
ZERNIO_API_KEY=sk_your_key_here

# Account IDs from your Zernio connected-accounts list (see README).
TIKTOK_ACCOUNT_ID=your_tiktok_account_id
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# Optional overrides (defaults shown):
# AUTOPOST_QUEUE_DIR=/mnt/ssd/social-queue
# AUTOPOST_CAPTIONS_DIR=/mnt/ssd/social-queue/captions
# AUTOPOST_LOG_FILE=/mnt/ssd/social-queue/autopost.log
# AUTOPOST_RECYCLE=1            # 0 = go quiet when the queue is empty instead of replaying old clips
# AUTOPOST_POSTS_PER_DAY=2      # only used for the dashboard's runway estimate — match your timer
# UPLOADER_PORT=5000
# UPLOADER_MAX_MB=500
